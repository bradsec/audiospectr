{
  "resolution": [1920, 1080],
  "fps": 30,
  "audio": "/tmp/test_tone.wav",
  "output": "/tmp/test_multilayer.mp4",
  "background": {
    "type": "color",
    "color": "#050510"
  },
  "metadata": {
    "title": "Test Track",
    "artist": "Test Artist"
  },
  "layers": [
    {
      "type": "bars",
      "x": 0, "y": 700, "width": 1920, "height": 380,
      "bar_count": 96,
      "color": "#00f5ff",
      "secondary_color": "#ff00cc",
      "mirror": true,
      "corner_radius": 4,
      "smoothing_type": "average",
      "smoothing_factor": 0.8,
      "effects": { "glow": true, "glow_intensity": 1.5 }
    },
    {
      "type": "text",
      "x": 80, "y": 60, "width": 1760, "height": 80,
      "content": "{artist} — {title}",
      "font_size": 52,
      "color": "#ffffff",
      "alignment": "left"
    },
    {
      "type": "timer",
      "x": 0, "y": 1065, "width": 1920, "height": 15,
      "color": "#00f5ff",
      "background_color": "#111111"
    }
  ]
}
